# Claude Cockpit — Environment Configuration
# Copy to .env and fill in the values for your setup

# ===== GitHub =====
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=mlopstapus
GITHUB_REPOS=mlopstapus/seamless  # comma-separated for multiple: repo1,repo2
GITHUB_POLL_INTERVAL=30

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== Local repo paths =====
# JSON map of "owner/repo" → absolute path on this machine
# Default fallback is ~/repos/<repo-name> if this is unset
REPO_LOCAL_PATHS={"mlopstapus/seamless":"/home/yourname/repos/seamless"}

# ===== Claude profiles =====
# Accounts are defined in config.py. Each account's config_dir must be a
# directory where you have already run `claude` and logged in.
# The default uses ~/.claude (the standard Claude Code config location).
# For multiple accounts, create separate dirs and run `claude login` in each.

# ===== Pipeline =====
# Set to false to suppress GitHub issue comments (useful during dev/testing)
PR_COMMENTS_ENABLED=true

# ===== Expo dev server =====
# Set to false to disable the automatic Expo restart after each successful implement
EXPO_RESTART_ENABLED=true

# ===== API =====
DEBUG=false
