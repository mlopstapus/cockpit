# Cockpit — Environment Configuration
# Copy to .env and fill in the values, or run: node setup/index.js

# ===== GitHub =====
# Personal access token — repo + issues scope required
GITHUB_TOKEN=your-github-token

# Your GitHub username or organisation that owns the repos to watch
GITHUB_OWNER=your-github-username

# Comma-separated list of repos to watch (do NOT use JSON array format)
# Example: your-org/repo1,your-org/repo2
GITHUB_REPOS=your-org/your-repo

# Seconds between GitHub polls (default: 30)
GITHUB_POLL_INTERVAL=30

# ===== Storage =====
# Path to the SQLite database file — created automatically on startup
# No external services required (Redis and Docker are not used)
DB_PATH=~/.cockpit/cockpit.db

# ===== Local repo paths =====
# JSON map of "owner/repo" → absolute path on this machine
# Default fallback: ~/repos/<repo-name> if unset
REPO_LOCAL_PATHS={"your-org/your-repo":"/home/yourname/repos/your-repo"}

# ===== Post-implement hook =====
# Optional: shell command run after each successful implement stage
# Executed via /bin/sh -c — full shell syntax supported (pipes, &&, env vars)
# Leave empty to disable. Example: systemctl --user restart my-app
# Expo migration: POST_IMPLEMENT_COMMAND=systemctl --user restart seamless-expo
POST_IMPLEMENT_COMMAND=

# ===== Pipeline =====
# Set to false to suppress GitHub issue comments (useful during dev/testing)
PR_COMMENTS_ENABLED=true

# ===== API =====
DEBUG=false

# ===== Future: GitHub Secrets =====
# Secrets can also be stored in GitHub Secrets/Environments and injected at
# runtime via your service's EnvironmentFile directive — useful for secrets
# rotation without touching the .env file on disk.
